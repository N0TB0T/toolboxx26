{
  "name": "toolboxx",
  "description": "Sketch productivity tools — public release",
  "version": "0.3.832",
  "engines": {
    "sketch": ">=49.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/N0TB0T/toolboxx26.git"
  },
  "skpm": {
    "name": "ToolBoxx",
    "manifest": "src/manifest.json",
    "main": "toolboxx.sketchplugin",
    "assets": [
      "assets/**/*"
    ]
  },
  "scripts": {
    "build": "skpm-build",
    "watch": "skpm-build --watch",
    "start": "skpm-build --watch --run",
    "postinstall": "npm run build && skpm-link"
  },
  "devDependencies": {
    "@skpm/builder": "^0.9.5"
  }
}
